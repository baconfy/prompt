{
  "name": "baconfy/prompt",
  "description": "Manage AI prompts in Laravel with Markdown + YAML front matter, multiple drivers (file/database), and Blade rendering.",
  "license": "GPL-3.0-or-later",
  "keywords": [
    "laravel",
    "prompt",
    "ai",
    "llm",
    "markdown",
    "blade",
    "front-matter"
  ],
  "type": "library",
  "authors": [
    {
      "name": "Baconfy",
      "homepage": "https://github.com/baconfy"
    }
  ],
  "require": {
    "php": "^8.3",
    "illuminate/console": "^12.0|^13.0",
    "illuminate/contracts": "^12.0|^13.0",
    "illuminate/database": "^12.0|^13.0",
    "illuminate/filesystem": "^12.0|^13.0",
    "illuminate/support": "^12.0|^13.0",
    "illuminate/view": "^12.0|^13.0",
    "symfony/yaml": "^7.0"
  },
  "require-dev": {
    "larastan/larastan": "^3.0",
    "laravel/pint": "^1.18",
    "orchestra/testbench": "^9.0|^10.0|^11.0",
    "pestphp/pest": "^3.0",
    "pestphp/pest-plugin-laravel": "^3.0"
  },
  "autoload": {
    "psr-4": {
      "Baconfy\\Prompt\\": "src/"
    },
    "files": [
      "src/helpers.php"
    ]
  },
  "autoload-dev": {
    "psr-4": {
      "Baconfy\\Prompt\\Database\\Factories\\": "database/factories",
      "Baconfy\\Prompt\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "pest --parallel --compact",
    "test:coverage": "pest --coverage --min=100 --parallel --compact",
    "test:types": "phpstan analyse",
    "format": "pint",
    "test:all": [
      "@test",
      "@test:coverage",
      "@test:types"
    ]
  },
  "extra": {
    "laravel": {
      "providers": [
        "Baconfy\\Prompt\\PromptServiceProvider"
      ],
      "aliases": {
        "Prompt": "Baconfy\\Prompt\\Facades\\Prompt"
      }
    }
  },
  "config": {
    "sort-packages": true,
    "allow-plugins": {
      "pestphp/pest-plugin": true
    }
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}